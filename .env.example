# 로컬 release 환경변수 템플릿. 실제 값은 .env 에 저장하고 절대 commit 금지.
# release-flipmd.sh가 자동으로 source 한다.

# minisign 비밀번호 (flipmd.key)
MINISIGN_PASSWORD='your-minisign-password-here'

# Apple Notarization — https://appleid.apple.com 에서 app-specific password 발급
# 한 번만 입력하면 release-flipmd.sh가 자동으로 keychain profile을 등록한다.
APPLE_ID='you@example.com'
APPLE_APP_PASSWORD='xxxx-xxxx-xxxx-xxxx'
APPLE_TEAM_ID='XU8HS9JUTS'

# (옵션) 기본값 override
# MINISIGN_SECRET_KEY=~/.tauri/flipmd.key
# APPLE_SIGNING_IDENTITY='Developer ID Application: YONGSUB LEE (XU8HS9JUTS)'
# APPLE_NOTARY_PROFILE='FLIPMD_NOTARY'
# KEYCHAIN_SERVICE=flipmd-minisign
